  },
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": "OnlineLiveSupport.com",
  "license": "MIT",
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "n8n-workflow": "^1.0.0",
