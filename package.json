{
  "name": "n8n-nodes-whatsapp-crm-marketing",
  "version": "1.0.1",
  "description": "n8n integration node for WhatsApp CRM, Marketing, Cart Recovery by OnlineLiveSupport.com",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "copyfiles -u 1 nodes/**/*.png nodes/**/*.svg dist/",
